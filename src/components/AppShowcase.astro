---
import translations from "../i18n/translations";
import { defaultLocale, type Locale } from "../i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = translations[lang] ?? translations[defaultLocale];

const blocks = [
  {
    eyebrow: t["showcase.smart"],
    title: t["showcase.snap"],
    body: t["showcase.snap.body"],
    points: [t["showcase.snap.point1"], t["showcase.snap.point2"], t["showcase.snap.point3"]],
    image: "/app_preview_4.jpg",
    imageAlt: "RecipLab app — ingredient recognition",
    reverse: false,
    tint: "primary",
  },
  {
    eyebrow: t["showcase.design"],
    title: t["showcase.simple"],
    body: t["showcase.simple.body"],
    points: [t["showcase.simple.point1"], t["showcase.simple.point2"], t["showcase.simple.point3"]],
    image: "/app_preview_2.jpg",
    imageAlt: "RecipLab app — recipe details",
    reverse: true,
    tint: "secondary",
  },
];
---

<section class="py-24 lg:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 space-y-28 lg:space-y-36">
    {blocks.map((block) => (
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Copy -->
        <div class={`lg:col-span-6 ${block.reverse ? "lg:order-2" : ""}`}>
          <div class={`text-sm font-semibold uppercase tracking-[0.2em] mb-4 ${block.tint === "primary" ? "text-primary-600" : "text-secondary-600"}`}>
            {block.eyebrow}
          </div>
          <h3 class="font-display text-2xl sm:text-3xl lg:text-4xl font-semibold text-neutral-900 leading-[1.05] mb-6">
            {block.title}
          </h3>
          <p class="text-lg text-neutral-600 leading-relaxed mb-8 max-w-lg">
            {block.body}
          </p>
          <ul class="space-y-3">
            {block.points.map((point) => (
              <li class="flex items-start gap-3">
                <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${block.tint === "primary" ? "text-primary-600" : "text-secondary-600"}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-neutral-800">{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Device -->
        <div class={`lg:col-span-6 ${block.reverse ? "lg:order-1" : ""}`}>
          <div class="relative mx-auto w-[260px] sm:w-[300px] lg:w-full lg:max-w-[380px]">
            <div aria-hidden="true" class={`absolute inset-0 -m-4 rounded-[3rem] ${block.tint === "primary" ? "bg-primary-100" : "bg-secondary-100"} ${block.reverse ? "-rotate-2" : "rotate-2"}`}></div>
            <div class="relative bg-neutral-900 rounded-[2.5rem] p-2 shadow-2xl border-[7px] border-neutral-900">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-neutral-900 rounded-b-2xl z-10"></div>
              <div class="relative aspect-[9/19] bg-white rounded-[1.75rem] overflow-hidden">
                <img src={block.image} alt={block.imageAlt} loading="lazy" decoding="async" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
