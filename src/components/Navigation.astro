---
import translations from "../i18n/translations";
import { locales, defaultLocale, localeLabels, type Locale } from "../i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = translations[lang] ?? translations[defaultLocale];
const homeHref = `/${lang}/`;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-neutral-100/80 backdrop-blur-md border-b border-border/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href={homeHref} class="flex items-center space-x-2 group rounded">
        <img src="/icon.png" alt={t["brand.logoAlt"]} class="h-10 w-auto transform group-hover:scale-110 transition-transform duration-300 rounded" />
        <span class="font-display text-xl font-semibold text-neutral-900">RecipLab</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-6">
        <a href={`${homeHref}#features`} class="text-neutral-700 hover:text-primary-600 transition-colors duration-300 font-medium">{t["nav.features"]}</a>
        <a href={`${homeHref}#plans`} class="text-neutral-700 hover:text-primary-600 transition-colors duration-300 font-medium">{t["nav.plans"]}</a>
        <a href={`/${lang}/blog/`} class="text-neutral-700 hover:text-primary-600 transition-colors duration-300 font-medium">{t["nav.blog"]}</a>
        <a href={`${homeHref}#cta`} class="px-5 py-2 bg-neutral-900 text-white rounded-full font-semibold hover:bg-neutral-800 transition-colors">{t["nav.getStarted"]}</a>
        <div class="flex items-center space-x-2 bg-white/60 border border-border rounded-full px-3 py-1">
          <span class="text-sm font-medium text-neutral-700 hidden lg:inline">{t["nav.language"]}</span>
          <label class="sr-only" for="language-selector">{t["nav.language"]}</label>
          <select id="language-selector" class="bg-transparent text-neutral-800 text-sm font-semibold focus:outline-none">
            {locales.map((l) => (
              <option value={l} selected={l === lang}>{localeLabels[l]}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-muted transition-colors" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface">
    <div class="px-4 py-4 space-y-3">
      <a href={`${homeHref}#features`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">{t["nav.features"]}</a>
      <a href={`${homeHref}#plans`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">{t["nav.plans"]}</a>
      <a href={`/${lang}/blog/`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 hover:text-primary-600 rounded-lg transition-colors">{t["nav.blog"]}</a>
      <a href={`${homeHref}#cta`} class="block px-4 py-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white text-center rounded-lg font-semibold">{t["nav.getStarted"]}</a>
      <div class="flex items-center justify-between px-4 py-2 bg-surface rounded-lg border border-border">
        <label for="language-selector-mobile" class="text-neutral-700 font-medium">{t["nav.language"]}</label>
        <select id="language-selector-mobile" class="bg-transparent text-neutral-800 text-sm font-semibold focus:outline-none">
          {locales.map((l) => (
            <option value={l} selected={l === lang}>{localeLabels[l]}</option>
          ))}
        </select>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
