---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/Navigation.astro";
import Footer from "../../../components/Footer.astro";
import translations from "../../../i18n/translations";
import { locales, defaultLocale, type Locale } from "../../../i18n/ui";

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = translations[lang] ?? translations[defaultLocale];

// Astro slugs include the directory ("en/save-tiktok-recipes"); we only want the leaf segment.
const postSlug = (p: { slug: string }) => p.slug.split("/").pop() ?? p.slug;

const all = await getCollection("blog", (entry) => !entry.data.draft);
// Posts for the current locale, fallback to English if no translation exists
const inLang = all.filter((p) => p.data.lang === lang);
const fallback = all.filter(
  (p) => p.data.lang === "en" && !inLang.some((p2) => postSlug(p2) === postSlug(p)),
);
const posts = [...inLang, ...fallback].sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const dateFmt = new Intl.DateTimeFormat(lang === "en" ? "en-US" : lang === "es" ? "es-ES" : "ca-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: t["blog.title"],
  description: t["blog.subtitle"],
  inLanguage: lang,
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.data.title,
    url: new URL(`/${lang}/blog/${postSlug(p)}/`, Astro.site).toString(),
    datePublished: p.data.publishedAt.toISOString(),
    author: { "@type": "Organization", name: p.data.author },
  })),
};
---

<Layout
  lang={lang}
  pageKey="blog"
  title={`${t["blog.title"]} — RecipLab`}
  description={t["blog.subtitle"]}
  structuredData={blogSchema}
>
  <Navigation lang={lang} />

  <main class="pt-28 pb-24 lg:pt-36 lg:pb-32 bg-neutral-100">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <header class="max-w-3xl mb-16">
        <div class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600 mb-4">
          {t["nav.blog"]}
        </div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-neutral-900 leading-[1.05] mb-6">
          {t["blog.title"]}
        </h1>
        <p class="text-lg text-neutral-600 leading-relaxed">
          {t["blog.subtitle"]}
        </p>
      </header>

      <!-- Post grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {posts.map((post) => (
          <a
            href={`/${lang}/blog/${postSlug(post)}/`}
            class="group flex flex-col overflow-hidden rounded-3xl bg-surface border border-border hover:border-neutral-900 transition-colors"
          >
            {post.data.heroImage && (
              <div class="aspect-[16/10] overflow-hidden bg-neutral-100">
                <img
                  src={post.data.heroImage}
                  alt={post.data.heroAlt ?? ""}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              </div>
            )}
            <div class="p-7 lg:p-8 flex flex-col flex-1">
              <div class="text-xs uppercase tracking-[0.15em] text-neutral-500 mb-3">
                {dateFmt.format(post.data.publishedAt)}
              </div>
              <h2 class="font-display text-2xl lg:text-[28px] font-semibold text-neutral-900 leading-tight mb-3">
                {post.data.title}
              </h2>
              <p class="text-neutral-600 leading-relaxed mb-6 flex-1">
                {post.data.excerpt}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-primary-600 group-hover:gap-3 transition-all">
                {t["blog.readArticle"]}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
