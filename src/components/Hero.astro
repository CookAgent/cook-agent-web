---
import translations from "../i18n/translations";
import { defaultLocale, type Locale } from "../i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = translations[lang] ?? translations[defaultLocale];
---

<section
  class="relative bg-neutral-100 overflow-hidden pt-28 pb-20 md:pt-32 md:pb-24 lg:pt-36 lg:pb-28"
>
  <!-- Soft ambient color washes -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-48 -right-48 w-[560px] h-[560px] rounded-full bg-primary-200/50 blur-3xl"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-40 -left-40 w-[460px] h-[460px] rounded-full bg-secondary-200/45 blur-3xl"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-y-16 gap-x-12 items-center"
    >
      <!-- COPY -->
      <div class="lg:col-span-7 xl:col-span-7 max-w-xl lg:max-w-none">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/70 backdrop-blur px-4 py-1.5 text-sm text-neutral-700 mb-7"
        >
          <span
            class="inline-block w-2 h-2 rounded-full bg-primary-500 animate-pulse"
          ></span>
          <span>{t["hero.tagline"]}</span>
        </div>

        <h1
          class="font-display font-semibold text-neutral-900 mb-7 text-[2.25rem] leading-[1.08] sm:text-4xl sm:leading-[1.05] md:text-5xl lg:text-[3.75rem] lg:leading-[1.02] xl:text-[4.25rem]"
        >
          <span class="block">{t["hero.title.line1"]}</span>
          <span class="block italic text-primary-600"
            >{t["hero.title.line2"]}</span
          >
        </h1>

        <p
          class="text-base sm:text-lg lg:text-xl text-neutral-700 leading-relaxed mb-9 max-w-xl"
          set:html={t["hero.subtitle"]}
        />

        <div class="flex flex-col sm:flex-row flex-wrap gap-3 mb-10">
          <a
            href="#cta"
            class="inline-flex items-center justify-center gap-2 px-6 sm:px-7 py-3.5 sm:py-4 rounded-full bg-neutral-900 text-white font-semibold hover:bg-neutral-800 transition-colors"
          >
            {t["hero.download"]}
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center px-6 sm:px-7 py-3.5 sm:py-4 rounded-full border border-neutral-300 text-neutral-900 font-semibold hover:border-neutral-900 transition-colors"
          >
            {t["hero.seeFeatures"]}
          </a>
        </div>

        <!-- Social proof row -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
          <div class="flex items-center gap-1">
            {
              [0, 1, 2, 3, 4].map(() => (
                <svg
                  class="w-4 h-4 text-warning-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))
            }
            <span class="ml-1 font-semibold text-neutral-900"
              >{t["hero.rating"]}</span
            >
          </div>
          <span class="hidden sm:inline h-4 w-px bg-neutral-300"></span>
          <span class="text-neutral-600">{t["hero.downloads"]}</span>
          <span class="hidden sm:inline h-4 w-px bg-neutral-300"></span>
          <span class="text-neutral-600">{t["hero.recipes"]}</span>
        </div>
      </div>

      <!-- DEVICE -->
      <div class="lg:col-span-5 xl:col-span-5">
        <div
          class="relative mx-auto w-full max-w-[400px] sm:max-w-[440px] lg:max-w-[460px] px-4 py-9"
        >
          <!-- Warm backdrop card, tilted -->
          <div
            aria-hidden="true"
            class="absolute inset-2 rounded-[2.75rem] bg-gradient-to-br from-primary-100 to-secondary-100 rotate-[2.5deg]"
          >
          </div>

          <!-- Main phone — behind -->
          <div class="relative mx-auto w-[78%] sm:w-[76%] z-10">
            <div
              class="relative bg-neutral-900 rounded-[2.25rem] p-[5px] shadow-2xl ring-1 ring-neutral-900/10"
            >
              <div
                class="absolute top-[6px] left-1/2 -translate-x-1/2 w-20 h-[18px] bg-neutral-900 rounded-b-2xl z-10"
              >
              </div>
              <div
                class="relative aspect-[1170/2420] bg-white rounded-[1.85rem] overflow-hidden"
              >
                <img
                  src="/app_preview_1.jpg"
                  alt="RecipLab app — recipe generated from a photo"
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>

          <!-- Secondary phone — smaller, bottom-right, in front (higher z-index), no rotation -->
          <div
            class="absolute -right-4 sm:-right-10 bottom-6 w-[50%] sm:w-[52%] z-30 pointer-events-none select-none"
          >
            <div
              class="relative bg-neutral-900 rounded-[1.5rem] p-[4px] shadow-xl ring-1 ring-neutral-900/10"
            >
              <div
                class="absolute top-[4px] left-1/2 -translate-x-1/2 w-14 h-[12px] bg-neutral-900 rounded-b-xl z-10"
              >
              </div>
              <div
                class="relative aspect-[1170/2420] bg-white rounded-[1.2rem] overflow-hidden"
              >
                <img
                  src="/app_preview_2.jpg"
                  alt=""
                  aria-hidden="true"
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
