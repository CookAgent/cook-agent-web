---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/Navigation.astro";
import Footer from "../../../components/Footer.astro";
import translations from "../../../i18n/translations";
import { locales, defaultLocale, type Locale } from "../../../i18n/ui";

// Astro slugs include the directory ("en/save-tiktok-recipes"); we only want the leaf segment.
const leaf = (p: { slug: string }) => p.slug.split("/").pop() ?? p.slug;

export async function getStaticPaths() {
  const all = await getCollection("blog", (entry) => !entry.data.draft);
  const leaf2 = (p: { slug: string }) => p.slug.split("/").pop() ?? p.slug;

  const paths: Array<{ params: { lang: Locale; slug: string }; props: { post: typeof all[number] } }> = [];

  for (const lang of locales) {
    const inLang = all.filter((p) => p.data.lang === lang);
    const fallback = all.filter(
      (p) => p.data.lang === "en" && !inLang.some((p2) => leaf2(p2) === leaf2(p)),
    );
    for (const post of [...inLang, ...fallback]) {
      paths.push({ params: { lang, slug: leaf2(post) }, props: { post } });
    }
  }

  return paths;
}

const { lang } = Astro.params as { lang: Locale };
const { post } = Astro.props as { post: Awaited<ReturnType<typeof getCollection>>[number] };
const slug = leaf(post);
const t = translations[lang] ?? translations[defaultLocale];
const { Content } = await post.render();

const dateFmt = new Intl.DateTimeFormat(lang === "en" ? "en-US" : lang === "es" ? "es-ES" : "ca-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Related posts (same lang fallback chain, excluding current)
const allPosts = await getCollection("blog", (entry) => !entry.data.draft);
const related = (post.data.relatedSlugs ?? [])
  .map((s) => {
    const inLang = allPosts.find((p) => leaf(p) === s && p.data.lang === lang);
    return inLang ?? allPosts.find((p) => leaf(p) === s && p.data.lang === "en");
  })
  .filter(Boolean) as typeof allPosts;

// Structured data: BlogPosting + optional FAQPage if the post has FAQs
const canonical = new URL(`/${lang}/blog/${slug}/`, Astro.site).toString();
const postSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.excerpt,
  image: post.data.heroImage,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  author: { "@type": "Organization", name: post.data.author, url: Astro.site?.toString() },
  publisher: {
    "@type": "Organization",
    name: "RecipLab",
    url: Astro.site?.toString(),
  },
  inLanguage: lang,
  mainEntityOfPage: canonical,
};

const faqSchema =
  post.data.faq && post.data.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: post.data.faq.map((f) => ({
          "@type": "Question",
          name: f.question,
          acceptedAnswer: { "@type": "Answer", text: f.answer },
        })),
      }
    : null;

const structuredData = faqSchema ? [postSchema, faqSchema] : postSchema;
---

<Layout
  lang={lang}
  pageKey={`blog/${slug}`}
  title={`${post.data.title} — RecipLab`}
  description={post.data.excerpt}
  structuredData={structuredData}
>
  <Navigation lang={lang} />

  <article class="pt-28 lg:pt-36 pb-24 lg:pb-32 bg-neutral-100">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <a href={`/${lang}/blog/`} class="inline-flex items-center gap-2 text-sm text-neutral-600 hover:text-neutral-900 mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        {t["blog.backToBlog"]}
      </a>

      <div class="text-xs uppercase tracking-[0.15em] text-neutral-500 mb-5">
        {dateFmt.format(post.data.publishedAt)}
        <span class="mx-2">·</span>
        {post.data.author}
      </div>

      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-neutral-900 leading-[1.05] mb-6">
        {post.data.title}
      </h1>

      <p class="text-lg lg:text-xl text-neutral-700 leading-relaxed mb-10">
        {post.data.excerpt}
      </p>
    </div>

    {post.data.heroImage && (
      <div class="max-w-5xl mx-auto px-6 lg:px-8 mb-14">
        <div class="rounded-3xl overflow-hidden aspect-[16/9] bg-neutral-200">
          <img
            src={post.data.heroImage}
            alt={post.data.heroAlt ?? ""}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    )}

    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-neutral-900 prose-p:text-neutral-700 prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-neutral-900 prose-li:text-neutral-700">
        <Content />
      </div>

      {post.data.keyPoints && post.data.keyPoints.length > 0 && (
        <aside class="mt-14 p-7 lg:p-8 rounded-3xl bg-surface border border-border">
          <h2 class="font-display text-xl font-semibold text-neutral-900 mb-5">Key points</h2>
          <ul class="space-y-4">
            {post.data.keyPoints.map((kp) => (
              <li>
                <div class="font-semibold text-neutral-900 mb-1">{kp.point}</div>
                <div class="text-neutral-600 text-sm leading-relaxed">{kp.detail}</div>
              </li>
            ))}
          </ul>
        </aside>
      )}

      {post.data.faq && post.data.faq.length > 0 && (
        <section class="mt-14">
          <h2 class="font-display text-2xl lg:text-3xl font-semibold text-neutral-900 mb-6">FAQ</h2>
          <div class="space-y-4">
            {post.data.faq.map((f) => (
              <details class="group rounded-2xl border border-border bg-surface">
                <summary class="cursor-pointer list-none p-5 lg:p-6 font-semibold text-neutral-900 flex items-center justify-between gap-4">
                  <span>{f.question}</span>
                  <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-neutral-700 leading-relaxed">
                  {f.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      {related.length > 0 && (
        <section class="mt-16 pt-10 border-t border-border">
          <h2 class="font-display text-2xl font-semibold text-neutral-900 mb-6">{t["blog.relatedTitle"]}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {related.map((r) => (
              <a href={`/${lang}/blog/${leaf(r)}/`} class="group block p-5 rounded-2xl border border-border bg-surface hover:border-neutral-900 transition-colors">
                <div class="text-xs uppercase tracking-[0.15em] text-neutral-500 mb-2">
                  {dateFmt.format(r.data.publishedAt)}
                </div>
                <div class="font-display text-lg font-semibold text-neutral-900 leading-tight">
                  {r.data.title}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>

  <Footer lang={lang} />
</Layout>
