---
import translations from "../i18n/translations";
import { defaultLocale, type Locale } from "../i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = translations[lang] ?? translations[defaultLocale];
---

<section id="cta" class="relative py-24 lg:py-32 bg-neutral-900 text-white overflow-hidden">
  <!-- Warm glow -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-40 bg-[radial-gradient(ellipse_at_center,rgba(198,90,74,0.6),transparent_60%)]"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -bottom-40 -left-40 w-[500px] h-[500px] rounded-full bg-secondary-500/10 blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.05] mb-6">
      {t["cta.title"]}
    </h2>
    <p class="text-lg lg:text-xl text-white/75 max-w-2xl mx-auto mb-12">
      {t["cta.subtitle"]}
    </p>

    <!-- Store badges -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-14">
      <a
        href="https://apps.apple.com/app/reciplab/id000000000"
        class="group inline-flex items-center gap-4 bg-white text-neutral-900 rounded-2xl px-6 py-4 font-semibold shadow-xl hover:scale-[1.02] transition-transform"
      >
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09997 22C7.78997 22.05 6.79997 20.68 5.95997 19.47C4.24997 17 2.93997 12.45 4.69997 9.39C5.56997 7.87 7.12997 6.91 8.81997 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/>
        </svg>
        <span class="text-left leading-tight">
          <span class="block text-[10px] uppercase tracking-wider text-neutral-500">{t["cta.downloadFor"]}</span>
          <span class="block text-lg font-bold">{t["cta.ios"]}</span>
        </span>
      </a>

      <div class="inline-flex items-center gap-4 bg-white/10 text-white/60 border border-white/10 rounded-2xl px-6 py-4 font-semibold cursor-default">
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
        </svg>
        <span class="text-left leading-tight">
          <span class="block text-[10px] uppercase tracking-wider text-white/40">Coming Soon</span>
          <span class="block text-lg font-bold">{t["cta.android"]}</span>
        </span>
      </div>
    </div>

    <!-- Trust row -->
    <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-3 text-sm text-white/70">
      <div class="inline-flex items-center gap-2">
        <svg class="w-4 h-4 text-warning-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span>{t["cta.rating"]}</span>
      </div>
      <span class="text-white/20">·</span>
      <span>{t["cta.users"]}</span>
      <span class="text-white/20">·</span>
      <span>{t["cta.free"]}</span>
    </div>
  </div>
</section>
